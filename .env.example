# Credit Assessment API — Environment Variables
# Copy this to .env for local development: cp .env.example .env

# API authentication (optional — leave empty to disable auth in dev mode)
# API_KEY=your-secret-api-key

# Deployment environment: development | staging | production
ENVIRONMENT=development

# CORS: JSON array of allowed origins
CORS_ORIGINS=["http://localhost:3000"]

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Database connection (default: local SQLite)
# DATABASE_URL=postgresql+asyncpg://credit:credit@localhost:5432/credit
DATABASE_URL=sqlite+aiosqlite:///./credit.db

# Server binding
HOST=0.0.0.0
PORT=8000
